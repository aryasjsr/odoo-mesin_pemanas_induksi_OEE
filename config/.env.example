# Docker-specific variables
DB_HOST=db
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoo_password_here
DB_NAME=odoo

# For Native Linux setup (uncomment and modify)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=odoo
# DB_PASSWORD=odoo

# For Native Windows setup (uncomment and modify)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=odoo
# DB_PASSWORD=odoo
# NOTE: On Windows, you may need to use %USERPROFILE%\.odoorc for config file

# Odoo Configuration
ODOO_PORT=8069
ADMIN_PASSWORD=admin_password_here
LANGUAGE=en_US
TIMEZONE=UTC

# Development Mode
DEV_MODE=all
LOG_LEVEL=debug
