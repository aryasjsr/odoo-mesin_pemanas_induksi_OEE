<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_operator_code" model="ir.ui.view">
        <field name="name">res.users.form.operator.code</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <field name="operator_code" placeholder="e.g. 0023"/>
            </xpath>
        </field>
    </record>
</odoo>
