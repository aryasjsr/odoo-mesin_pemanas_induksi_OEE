<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Test Wizard View -->
    <record id="modbus_test_wizard_form" model="ir.ui.view">
        <field name="name">mrp.modbus.test.wizard.form</field>
        <field name="model">mrp.modbus.test.wizard</field>
        <field name="arch" type="xml">
            <form string="Modbus Connection Test">
                <sheet>
                    <group>
                        <field name="config_id" readonly="1"/>
                        <field name="connection_ok" widget="boolean_toggle" readonly="1"/>
                    </group>
                    <group string="Test Results" invisible="not test_result">
                        <field name="test_result" nolabel="1" widget="text" readonly="1"
                               style="font-family: monospace; font-size: 12px;"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run_test" string="▶ Run Test" type="object"
                            class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
