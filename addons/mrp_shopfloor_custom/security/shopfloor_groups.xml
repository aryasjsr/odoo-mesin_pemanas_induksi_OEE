<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Module category for Shop Floor -->
        <record id="module_category_shopfloor" model="ir.module.category">
            <field name="name">Shop Floor</field>
            <field name="description">Shop Floor Operator Access</field>
            <field name="sequence">50</field>
        </record>

        <!-- Shopfloor Operator Group -->
        <record id="group_shopfloor_operator" model="res.groups">
            <field name="name">Operator</field>
            <field name="category_id" ref="module_category_shopfloor"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Shop Floor operators can only access Shop Floor, OEE Dashboard, and Quality menus.</field>
        </record>

        <!-- =================================================================
             HIDE Manufacturing sub-menus that operators should NOT see.
             We do this by adding groups to those menus so only MRP Manager
             (or users with mrp.group_mrp_manager) can see them.
             Operators don't have mrp.group_mrp_manager, so they won't see them.
             ================================================================= -->

        <!-- Hide: Manufacturing > Operations (MO list, WO list, etc.) -->
        <record id="mrp.menu_mrp_manufacturing" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('mrp.group_mrp_manager'))]"/>
        </record>

        <!-- Hide: Manufacturing > Products -->
        <record id="mrp.menu_mrp_bom" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('mrp.group_mrp_manager'))]"/>
        </record>

        <!-- Hide: Manufacturing > Reporting -->
        <record id="mrp.menu_mrp_reporting" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('mrp.group_mrp_manager'))]"/>
        </record>

        <!-- Hide: Manufacturing > Configuration -->
        <record id="mrp.menu_mrp_configuration" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('mrp.group_mrp_manager'))]"/>
        </record>
    </data>
</odoo>
