<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action: OEE Dashboard -->
    <record id="action_oee_dashboard" model="ir.actions.client">
        <field name="name">OEE Dashboard</field>
        <field name="tag">oee_dashboard</field>
        <field name="target">main</field>
    </record>

    <!-- Action: Loss Reasons (Community-friendly access) -->
    <record id="action_loss_reasons" model="ir.actions.act_window">
        <field name="name">Loss Reasons</field>
        <field name="res_model">mrp.workcenter.productivity.loss</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new loss reason
            </p>
            <p>Loss reasons are used to categorize downtime on work centers (e.g. Equipment Failure, Material Shortage).</p>
        </field>
    </record>

    <!-- Top-level Menu under Manufacturing -->
    <menuitem id="menu_oee_root"
              name="OEE"
              parent="mrp.menu_mrp_root"
              sequence="100"/>

    <menuitem id="menu_oee_dashboard"
              name="Dashboard"
              parent="menu_oee_root"
              action="action_oee_dashboard"
              sequence="10"/>

    <menuitem id="menu_oee_loss_reasons"
              name="Loss Reasons"
              parent="menu_oee_root"
              action="action_loss_reasons"
              sequence="20"/>
</odoo>
