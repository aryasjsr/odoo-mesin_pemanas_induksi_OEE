<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action: OEE Dashboard -->
    <record id="action_oee_dashboard" model="ir.actions.client">
        <field name="name">OEE Dashboard</field>
        <field name="tag">oee_dashboard</field>
        <field name="target">main</field>
    </record>

    <!-- Top-level Menu under Manufacturing -->
    <menuitem id="menu_oee_root"
              name="OEE"
              parent="mrp.menu_mrp_root"
              sequence="100"/>

    <menuitem id="menu_oee_dashboard"
              name="Dashboard"
              parent="menu_oee_root"
              action="action_oee_dashboard"
              sequence="10"/>
</odoo>
